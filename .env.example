# ─────────────────────────────────────────────────────────────────────────────
# Family Glucose Monitor — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# Priority: environment variables > config.yaml
# In production, critical secrets MUST come from environment variables.
# In local/dev environments, config.yaml fallback is allowed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Encryption ───────────────────────────────────────────────────────────────
# Master encryption key for Fernet (AES-128-CBC + HMAC-SHA256).
# Must be a 64-character hex string (32 raw bytes).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# In production: inject via Docker secret, Kubernetes secret, or vault.
# If not set, a .secret_key file is created at the project root (dev only).
FGM_MASTER_KEY=

# ── External API authentication ──────────────────────────────────────────────
# API key for the external REST API (api_server.py, port 8081 by default).
# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── LibreLinkUp credentials (alternative to config.yaml) ────────────────────
# These override librelinkup.email and librelinkup.password in config.yaml.
# Useful to avoid storing plain-text credentials in the config file.
LIBRELINKUP_EMAIL=
LIBRELINKUP_PASSWORD=

# ── Alert history database path ──────────────────────────────────────────────
# Overrides config.alert_history_db. Defaults to <project_root>/alert_history.db
# ALERT_HISTORY_DB=/data/alert_history.db

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Overrides the access_token in the whatsapp output configuration.
# WHATSAPP_ACCESS_TOKEN=

# ── Dashboard / app environment ──────────────────────────────────────────────
# Set to "development" (or "dev", "local", "test") to enable dev-friendly
# behaviours: non-Secure cookies, AUTH_DISABLED support.
# Defaults to "production" if not set (Secure cookies enforced, AUTH_DISABLED ignored).
# APP_ENV=production

# ── Development / insecure overrides (NEVER use in production) ───────────────
# Set to 1 to allow the external API to run without API_KEY authentication.
# Only for local development or trusted private networks.
# ALLOW_INSECURE_LOCAL_API=1

# Set to 1 to disable dashboard authentication (for automated tests only).
# AUTH_DISABLED=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the external API.
# Example: http://localhost:3000,https://dashboard.example.com
# CORS_ALLOWED_ORIGINS=
